<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('partials/head', { titulo: 'Minhas Reservas', paginaCSS: 'vitrine' }) %>
</head>

<body data-bs-theme="dark">

  <%- include('partials/navbar', { paginaAtiva: 'vitrine' }) %>

  <main class="container py-5 mt-3">

    <div class="d-flex align-items-center gap-3 mb-4">
      <a href="/vitrine" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i>Voltar à vitrine
      </a>
      <div>
        <h1 class="titulo-servico mb-0" style="font-size:1.8rem;">Minhas Reservas</h1>
        <div class="mt-1" style="width:40px;height:3px;background:var(--cor-dourado);border-radius:2px;"></div>
      </div>
    </div>

    <!-- ALERTAS -->
    <% if (sucesso) { %>
      <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i><%= sucesso %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (erro) { %>
      <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i><%= erro %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (reservas && reservas.length > 0) { %>

      <div class="row row-cols-1 row-cols-md-2 g-4">
        <% reservas.forEach(function(r) { %>
          <div class="col">
            <div class="card vitrine-card border-0 h-100">
              <div class="card-body p-4">

                <div class="d-flex align-items-start gap-3">

                  <!-- IMAGEM -->
                  <% if (r.id_produto && r.id_produto.imagem_url) { %>
                    <img
                      src="<%= r.id_produto.imagem_url %>"
                      alt="<%= r.id_produto.descricao %>"
                      class="rounded"
                      style="width:72px;height:72px;object-fit:cover;flex-shrink:0;"
                    >
                  <% } else { %>
                    <div class="rounded d-flex align-items-center justify-content-center"
                      style="width:72px;height:72px;background:rgba(255,255,255,0.05);flex-shrink:0;">
                      <i class="fa-solid fa-image text-muted opacity-25 fa-2x"></i>
                    </div>
                  <% } %>

                  <!-- DADOS -->
                  <div class="flex-grow-1 min-w-0">
                    <h6 class="mb-1 text-truncate">
                      <%= r.id_produto ? r.id_produto.descricao : 'Produto removido' %>
                    </h6>

                    <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                      <!-- STATUS BADGE -->
                      <%
                        const statusMap = {
                          'Pendente':   'bg-warning text-dark',
                          'Confirmada': 'bg-success',
                          'Retirada':   'bg-secondary',
                          'Cancelada':  'bg-danger'
                        };
                        const badgeClass = statusMap[r.status] || 'bg-secondary';
                      %>
                      <span class="badge <%= badgeClass %>"><%= r.status %></span>
                      <span class="text-muted small">Qtd: <%= r.quantidade %></span>
                    </div>

                    <% if (r.id_produto) { %>
                      <p class="small text-warning mb-1">
                        R$ <%= (r.preco_unitario_reserva || r.id_produto.preco_venda || 0).toFixed(2).replace('.', ',') %> / un
                      </p>
                    <% } %>

                    <p class="text-muted small mb-0">
                      Reservado em: <%= new Date(r.createdAt).toLocaleDateString('pt-BR') %>
                    </p>

                    <% if (r.data_retirada_prevista) { %>
                      <p class="text-muted small mb-0">
                        Retirada prevista: <%= new Date(r.data_retirada_prevista).toLocaleDateString('pt-BR') %>
                      </p>
                    <% } %>

                    <% if (r.observacao) { %>
                      <p class="text-muted small mb-0 mt-1">
                        <em>"<%= r.observacao %>"</em>
                      </p>
                    <% } %>
                  </div>

                </div>

              </div>
            </div>
          </div>
        <% }); %>
      </div>

    <% } else { %>
      <div class="text-center py-5 opacity-50">
        <i class="fa-solid fa-bag-shopping fa-4x mb-3" style="color:var(--cor-dourado);"></i>
        <p class="fs-5">Você ainda não tem reservas.</p>
        <a href="/vitrine" class="btn btn-vitrine btn-sm mt-2 px-4">
          <i class="fa-solid fa-store me-2"></i>Explorar vitrine
        </a>
      </div>
    <% } %>

  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
