<!DOCTYPE html>
<html lang="pt-br">
<head><%- include('partials/head', { titulo: 'Fornecedores' }) %></head>
<body data-bs-theme="dark">
  <div class="layout-admin">
    <%- include('partials/sidebarAdmin', { paginaAdmin: 'fornecedores' }) %>
    <main class="conteudo-admin">
      <div class="d-flex align-items-center gap-3 mb-4 flex-wrap"><button class="btn btn-sm btn-outline-warning d-lg-none" id="sidebarOpen" aria-label="Menu"><i class="fas fa-bars"></i></button><div><h1 class="text-dourado mb-0" style="font-family:var(--fonte-titulo);font-size:1.8rem;"><i class="fas fa-truck-field me-2"></i>Fornecedores</h1><p class="text-secondary small mb-0">Cadastro simples de fornecedores de produtos e insumos.</p></div></div>
      <% if (erro) { %><div class="alert alert-danger border-0 small mb-4"><i class="fas fa-exclamation-triangle me-2"></i><%= erro %></div><% } %>
      <% if (sucesso) { %><div class="alert alert-success border-0 small mb-4"><i class="fas fa-check-circle me-2"></i><%= sucesso %></div><% } %>
      <div class="card p-4 mb-4"><h6 class="text-dourado mb-3"><i class="fas fa-plus me-2"></i>Novo fornecedor</h6><form action="/fornecedores" method="POST" class="row g-3"><div class="col-lg-4"><label class="form-label small text-secondary">Razão social</label><input class="form-control" name="razao_social" required></div><div class="col-lg-2"><label class="form-label small text-secondary">CNPJ</label><input class="form-control" name="cnpj" maxlength="18"></div><div class="col-lg-2"><label class="form-label small text-secondary">Telefone</label><input class="form-control" name="telefone"></div><div class="col-lg-3"><label class="form-label small text-secondary">E-mail</label><input class="form-control" type="email" name="email"></div><div class="col-lg-1 d-flex align-items-end"><button class="btn-dourado w-100" type="submit">Salvar</button></div></form></div>
      <div class="card p-4"><h6 class="text-dourado mb-3"><i class="fas fa-list me-2"></i>Fornecedores cadastrados</h6><div class="table-responsive"><table class="table table-dark table-hover align-middle"><thead><tr><th>Razão social</th><th>CNPJ</th><th>Telefone</th><th>E-mail</th><th>Cidade/UF</th><th>Status</th></tr></thead><tbody><% if ((fornecedores || []).length) { %><% fornecedores.forEach(f => { %><tr><td><%= f.razao_social %></td><td class="small text-secondary"><%= f.cnpj || '—' %></td><td class="small"><%= f.telefone || '—' %></td><td class="small"><%= f.email || '—' %></td><td class="small"><%= f.cidade || '—' %>/<%= f.estado || '—' %></td><td><span class="badge bg-<%= f.flg_ativo ? 'success' : 'secondary' %>"><%= f.flg_ativo ? 'Ativo' : 'Inativo' %></span></td></tr><% }) %><% } else { %><tr><td colspan="6" class="text-center text-secondary py-4">Nenhum fornecedor cadastrado.</td></tr><% } %></tbody></table></div></div>
    </main>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script><script src="/assets/js/admin.js"></script>
</body>
</html>
