<%#
  PARTIAL: head.ejs
  USO: include('partials/head', { titulo: 'Título da Página', paginaCSS: 'nome-pagina' })
  paginaCSS é opcional — carrega /assets/css/<paginaCSS>.css se informado
%>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof titulo !== 'undefined' ? titulo : 'Studio Patty Leão' %> | Studio Patty Leão</title>

<!-- Favicon -->
<link rel="shortcut icon" type="image/png" href="/assets/img/favicon.png">

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Questrial&family=Quicksand:wght@300..700&family=Yeseva+One&display=swap" rel="stylesheet">

<!-- Font Awesome -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">

<!-- CSS Base -->
<link rel="stylesheet" href="/assets/css/base.css">

<% if (typeof paginaCSS !== 'undefined' && paginaCSS) { %>
<link rel="stylesheet" href="/assets/css/<%= paginaCSS %>.css">
<% } %>
