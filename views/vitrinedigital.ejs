<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('partials/head', { titulo: 'Vitrine Digital', paginaCSS: 'vitrine' }) %>
</head>

<body data-bs-theme="dark">

  <%- include('partials/navbar', { paginaAtiva: 'vitrine' }) %>

  <main class="container py-5 mt-3">

    <!-- CABEÇALHO DA PÁGINA -->
    <div class="text-center mb-5">
      <h1 class="titulo-servico">Vitrine Digital</h1>
      <div class="mx-auto mt-2 mb-3" style="width:60px;height:3px;background:var(--cor-dourado);border-radius:2px;"></div>
      <p class="text-muted">Produtos selecionados pelo nosso salão para cuidar dos seus cabelos em casa.</p>
    </div>

    <!-- ALERTAS DE FEEDBACK -->
    <% if (sucesso) { %>
      <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i><%= sucesso %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
      </div>
    <% } %>

    <% if (erro) { %>
      <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i><%= erro %>
        <button type="button" class="btn-dismiss btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
      </div>
    <% } %>

    <!-- AVISO DE LOGIN PARA RESERVAR -->
    <% if (!usuario) { %>
      <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="fa-solid fa-lock"></i>
        <span>Para reservar produtos, <a href="/login" class="alert-link">faça login</a> ou <a href="/cadastro" class="alert-link">crie sua conta</a>.</span>
      </div>
    <% } %>

    <!-- GRADE DE PRODUTOS -->
    <% if (produtos && produtos.length > 0) { %>
      <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">

        <% produtos.forEach(function(produto) { %>
          <div class="col">
            <div class="card vitrine-card h-100 border-0">

              <!-- IMAGEM DO PRODUTO -->
              <div class="vitrine-card-img-wrap">
                <% if (produto.imagem_url) { %>
                  <img
                    src="<%= produto.imagem_url %>"
                    class="card-img-top vitrine-img"
                    alt="<%= produto.descricao %>"
                    loading="lazy"
                  >
                <% } else { %>
                  <div class="vitrine-img-placeholder d-flex align-items-center justify-content-center">
                    <i class="fa-solid fa-image fa-3x text-muted opacity-25"></i>
                  </div>
                <% } %>
              </div>

              <!-- CORPO DO CARD -->
              <div class="card-body d-flex flex-column gap-2 p-4">
                <h5 class="card-title mb-0"><%= produto.descricao %></h5>

                <% if (produto.descricao_vitrine) { %>
                  <p class="card-text text-muted small mb-0"><%= produto.descricao_vitrine %></p>
                <% } %>

                <div class="mt-auto pt-3">
                  <p class="vitrine-preco mb-3">
                    R$ <%= produto.preco_venda.toFixed(2).replace('.', ',') %>
                  </p>

                  <!-- FORMULÁRIO DE RESERVA -->
                  <% if (usuario) { %>
                    <button
                      type="button"
                      class="btn btn-vitrine w-100"
                      data-bs-toggle="modal"
                      data-bs-target="#modalReserva"
                      data-produto-id="<%= produto._id %>"
                      data-produto-nome="<%= produto.descricao %>"
                      data-produto-preco="R$ <%= produto.preco_venda.toFixed(2).replace('.', ',') %>"
                    >
                      <i class="fa-solid fa-bag-shopping me-2"></i>Reservar
                    </button>
                  <% } else { %>
                    <a href="/login" class="btn btn-outline-secondary w-100">
                      <i class="fa-solid fa-lock me-2"></i>Login para reservar
                    </a>
                  <% } %>
                </div>
              </div>

            </div>
          </div>
        <% }); %>

      </div><!-- /row -->

    <% } else { %>
      <!-- ESTADO VAZIO -->
      <div class="text-center py-5 opacity-50">
        <i class="fa-solid fa-store-slash fa-4x mb-3" style="color:var(--cor-dourado);"></i>
        <p class="fs-5">Nenhum produto disponível no momento.</p>
        <p class="text-muted small">Em breve novidades por aqui!</p>
      </div>
    <% } %>

    <!-- LINK PARA MINHAS RESERVAS (usuário logado) -->
    <% if (usuario) { %>
      <div class="text-center mt-5">
        <a href="/vitrine/minhas-reservas" class="btn btn-outline-warning btn-sm px-4">
          <i class="fa-solid fa-clock-rotate-left me-2"></i>Ver minhas reservas
        </a>
      </div>
    <% } %>

  </main>

  <!-- MODAL DE RESERVA -->
  <div class="modal fade" id="modalReserva" tabindex="-1" aria-labelledby="modalReservaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content vitrine-modal">

        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title" id="modalReservaLabel">
            <i class="fa-solid fa-bag-shopping me-2" style="color:var(--cor-dourado);"></i>Confirmar Reserva
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>

        <form action="/vitrine/reservar" method="POST">
          <div class="modal-body pt-3">

            <input type="hidden" name="id_produto" id="modal-id-produto">

            <p class="mb-3">
              Produto: <strong id="modal-nome-produto" class="text-warning"></strong><br>
              <small class="text-muted">Valor: <span id="modal-preco-produto"></span></small>
            </p>

            <div class="mb-3">
              <label for="modal-quantidade" class="form-label">Quantidade</label>
              <input
                type="number"
                id="modal-quantidade"
                name="quantidade"
                class="form-control vitrine-input"
                min="1" max="10" value="1"
                required
              >
              <div class="form-text text-muted">Máximo 10 unidades por reserva.</div>
            </div>

            <div class="mb-3">
              <label for="modal-data-retirada" class="form-label">Data prevista de retirada <span class="text-muted">(opcional)</span></label>
              <input
                type="date"
                id="modal-data-retirada"
                name="data_retirada_prevista"
                class="form-control vitrine-input"
              >
              <div class="form-text text-muted">Mínimo: amanhã.</div>
            </div>

            <div class="mb-2">
              <label for="modal-observacao" class="form-label">Observação <span class="text-muted">(opcional)</span></label>
              <textarea
                id="modal-observacao"
                name="observacao"
                class="form-control vitrine-input"
                rows="2"
                maxlength="250"
                placeholder="Ex: prefiro retirar à tarde..."
              ></textarea>
            </div>

            <div class="alert alert-info small py-2 mt-3 mb-0">
              <i class="fa-solid fa-circle-info me-1"></i>
              A reserva <strong>não realiza pagamento</strong>. O salão entrará em contato para confirmar a disponibilidade e combinar a retirada presencial.
            </div>

          </div>

          <div class="modal-footer border-0 pt-0">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-vitrine btn-sm px-4">
              <i class="fa-solid fa-check me-1"></i>Confirmar reserva
            </button>
          </div>
        </form>

      </div>
    </div>
  </div>
  <!-- /MODAL -->

  <%- include('partials/footer') %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Preenche modal com dados do produto clicado -->
  <script>
    const modalReserva = document.getElementById('modalReserva');
    if (modalReserva) {
      modalReserva.addEventListener('show.bs.modal', function (event) {
        const btn         = event.relatedTarget;
        const id          = btn.dataset.produtoId;
        const nome        = btn.dataset.produtoNome;
        const preco       = btn.dataset.produtoPreco;

        document.getElementById('modal-id-produto').value    = id;
        document.getElementById('modal-nome-produto').textContent  = nome;
        document.getElementById('modal-preco-produto').textContent = preco;

        // Define data mínima = amanhã
        const amanha = new Date();
        amanha.setDate(amanha.getDate() + 1);
        document.getElementById('modal-data-retirada').min =
          amanha.toISOString().split('T')[0];
      });
    }
  </script>

</body>
</html>
