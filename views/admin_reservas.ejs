<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('partials/head', { titulo: 'Reservas — Admin', paginaCSS: 'vitrine' }) %>
</head>

<body data-bs-theme="dark">

  <%- include('partials/navbar', { paginaAtiva: 'vitrine' }) %>

  <main class="container-fluid py-4 mt-3 px-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <div>
        <h1 class="titulo-servico mb-0" style="font-size:1.8rem;">Reservas da Vitrine</h1>
        <div class="mt-1" style="width:40px;height:3px;background:var(--cor-dourado);border-radius:2px;"></div>
      </div>
      <a href="/vitrine" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-store me-1"></i>Ver vitrine pública
      </a>
    </div>

    <!-- CARDS DE RESUMO -->
    <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
      <div class="col">
        <div class="card vitrine-card border-0 text-center py-3">
          <div class="fs-1 fw-bold text-warning"><%= reservas.length %></div>
          <div class="text-muted small">Total</div>
        </div>
      </div>
      <div class="col">
        <div class="card vitrine-card border-0 text-center py-3">
          <div class="fs-1 fw-bold text-warning"><%= pendentes %></div>
          <div class="text-muted small">Pendentes</div>
        </div>
      </div>
      <div class="col">
        <div class="card vitrine-card border-0 text-center py-3">
          <div class="fs-1 fw-bold text-success"><%= confirmadas %></div>
          <div class="text-muted small">Confirmadas</div>
        </div>
      </div>
      <div class="col">
        <div class="card vitrine-card border-0 text-center py-3">
          <div class="fs-1 fw-bold text-secondary">
            <%= reservas.filter(r => r.status === 'Retirada').length %>
          </div>
          <div class="text-muted small">Retiradas</div>
        </div>
      </div>
    </div>

    <!-- ALERTAS -->
    <% if (sucesso) { %>
      <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i><%= sucesso %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (erro) { %>
      <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i><%= erro %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- TABELA DE RESERVAS -->
    <% if (reservas && reservas.length > 0) { %>

      <!-- VERSÃO MOBILE: CARDS -->
      <div class="d-md-none">
        <% reservas.forEach(function(r) { %>
          <%
            const statusMap = {
              'Pendente':   'bg-warning text-dark',
              'Confirmada': 'bg-success',
              'Retirada':   'bg-secondary',
              'Cancelada':  'bg-danger'
            };
            const badgeClass = statusMap[r.status] || 'bg-secondary';
          %>
          <div class="card vitrine-card border-0 mb-3">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <strong class="d-block"><%= r.id_cliente ? r.id_cliente.nome : 'Cliente removido' %></strong>
                  <small class="text-muted"><%= r.id_cliente && r.id_cliente.telefone ? r.id_cliente.telefone : '—' %></small>
                </div>
                <span class="badge <%= badgeClass %>"><%= r.status %></span>
              </div>
              <p class="mb-1 small">
                <strong>Produto:</strong> <%= r.id_produto ? r.id_produto.descricao : '—' %><br>
                <strong>Qtd:</strong> <%= r.quantidade %> &nbsp;
                <strong>SKU:</strong> <%= r.id_produto && r.id_produto.sku ? r.id_produto.sku : '—' %><br>
                <strong>Valor un.:</strong> R$ <%= (r.preco_unitario_reserva || 0).toFixed(2).replace('.', ',') %><br>
                <strong>Reservado:</strong> <%= new Date(r.createdAt).toLocaleDateString('pt-BR') %>
                <% if (r.data_retirada_prevista) { %>
                  &nbsp;<strong>Retirada:</strong> <%= new Date(r.data_retirada_prevista).toLocaleDateString('pt-BR') %>
                <% } %>
              </p>
              <% if (r.observacao) { %>
                <p class="text-muted small mb-2"><em>"<%= r.observacao %>"</em></p>
              <% } %>
              <form action="/vitrine/admin/<%= r._id %>/status" method="POST" class="d-flex gap-2 flex-wrap mt-2">
                <select name="status" class="form-select form-select-sm vitrine-input" style="max-width:160px;">
                  <% ['Pendente','Confirmada','Retirada','Cancelada'].forEach(function(s) { %>
                    <option value="<%= s %>" <%= r.status === s ? 'selected' : '' %>><%= s %></option>
                  <% }); %>
                </select>
                <button type="submit" class="btn btn-vitrine btn-sm px-3">Salvar</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>

      <!-- VERSÃO DESKTOP: TABELA -->
      <div class="d-none d-md-block">
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle" style="font-size:.875rem;">
            <thead>
              <tr style="border-bottom:1px solid var(--cor-borda);">
                <th>Cliente</th>
                <th>Produto</th>
                <th class="text-center">Qtd</th>
                <th class="text-end">Valor un.</th>
                <th>Reservado em</th>
                <th>Retirada prevista</th>
                <th>Observação</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% reservas.forEach(function(r) { %>
                <%
                  const statusMap = {
                    'Pendente':   'bg-warning text-dark',
                    'Confirmada': 'bg-success',
                    'Retirada':   'bg-secondary',
                    'Cancelada':  'bg-danger'
                  };
                  const badgeClass = statusMap[r.status] || 'bg-secondary';
                %>
                <tr>
                  <td>
                    <strong><%= r.id_cliente ? r.id_cliente.nome : '—' %></strong><br>
                    <small class="text-muted"><%= r.id_cliente && r.id_cliente.telefone ? r.id_cliente.telefone : '' %></small>
                  </td>
                  <td>
                    <%= r.id_produto ? r.id_produto.descricao : '—' %><br>
                    <% if (r.id_produto && r.id_produto.sku) { %>
                      <small class="text-muted">SKU: <%= r.id_produto.sku %></small>
                    <% } %>
                  </td>
                  <td class="text-center"><%= r.quantidade %></td>
                  <td class="text-end">R$ <%= (r.preco_unitario_reserva || 0).toFixed(2).replace('.', ',') %></td>
                  <td><%= new Date(r.createdAt).toLocaleDateString('pt-BR') %></td>
                  <td>
                    <%= r.data_retirada_prevista
                      ? new Date(r.data_retirada_prevista).toLocaleDateString('pt-BR')
                      : '—' %>
                  </td>
                  <td>
                    <% if (r.observacao) { %>
                      <span class="text-muted small" title="<%= r.observacao %>">
                        <%= r.observacao.length > 40 ? r.observacao.substring(0, 40) + '…' : r.observacao %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td><span class="badge <%= badgeClass %>"><%= r.status %></span></td>
                  <td>
                    <form action="/vitrine/admin/<%= r._id %>/status" method="POST" class="d-flex gap-2 align-items-center">
                      <select name="status" class="form-select form-select-sm vitrine-input" style="min-width:130px;">
                        <% ['Pendente','Confirmada','Retirada','Cancelada'].forEach(function(s) { %>
                          <option value="<%= s %>" <%= r.status === s ? 'selected' : '' %>><%= s %></option>
                        <% }); %>
                      </select>
                      <button type="submit" class="btn btn-vitrine btn-sm px-3">
                        <i class="fa-solid fa-floppy-disk"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

    <% } else { %>
      <div class="text-center py-5 opacity-50">
        <i class="fa-solid fa-inbox fa-4x mb-3" style="color:var(--cor-dourado);"></i>
        <p class="fs-5">Nenhuma reserva encontrada.</p>
      </div>
    <% } %>

  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
