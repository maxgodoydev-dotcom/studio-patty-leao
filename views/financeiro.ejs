<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('partials/head', { titulo: 'Financeiro' }) %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body data-bs-theme="dark">

  <div class="layout-admin">

    <%- include('partials/sidebarAdmin', { paginaAdmin: 'financeiro' }) %>

    <main class="conteudo-admin">

      <!-- HEADER -->
      <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <button class="btn btn-sm btn-outline-warning d-lg-none" id="sidebarOpen" aria-label="Menu">
          <i class="fas fa-bars"></i>
        </button>
        <div>
          <h1 class="text-dourado mb-0" style="font-family:var(--fonte-titulo);font-size:1.8rem;">
            <i class="fas fa-chart-line me-2"></i>Financeiro Manual
          </h1>
          <p class="text-secondary small mb-0">Entradas, saídas e caixa simples presencial</p>
        </div>
      </div>

      <% if (typeof erro !== 'undefined' && erro) { %>
        <div class="alert alert-danger border-0 mb-3"><i class="fas fa-triangle-exclamation me-2"></i><%= erro %></div>
      <% } %>
      <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <div class="alert alert-success border-0 mb-3"><i class="fas fa-check-circle me-2"></i><%= sucesso %></div>
      <% } %>

      <!-- STATUS DO CAIXA -->
      <div class="card p-3 mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h6 class="text-dourado mb-1"><i class="fas fa-cash-register me-2"></i>Caixa do dia</h6>
            <% if (typeof caixaAberto !== 'undefined' && caixaAberto) { %>
              <p class="text-success mb-0 small">Caixa aberto desde <%= new Date(caixaAberto.data_abertura).toLocaleString('pt-BR') %></p>
              <p class="text-secondary mb-0 small">Saldo inicial: R$ <%= Number(caixaAberto.saldo_inicial || 0).toFixed(2) %></p>
            <% } else { %>
              <p class="text-secondary mb-0 small">Nenhum caixa aberto no momento.</p>
            <% } %>
          </div>

          <% if (typeof caixaAberto !== 'undefined' && caixaAberto) { %>
            <form action="/financeiro/caixa/fechar" method="POST" class="d-flex gap-2 flex-wrap align-items-end">
              <div>
                <label class="form-label small text-secondary mb-1">Saldo final contado</label>
                <input type="number" step="0.01" min="0" name="saldo_final" class="form-control form-control-sm" placeholder="Opcional">
              </div>
              <div>
                <label class="form-label small text-secondary mb-1">Observação</label>
                <input type="text" name="observacoes" class="form-control form-control-sm" maxlength="180" placeholder="Opcional">
              </div>
              <button type="submit" class="btn btn-sm btn-outline-warning">
                <i class="fas fa-lock me-1"></i>Fechar caixa
              </button>
            </form>
          <% } else { %>
            <form action="/financeiro/caixa/abrir" method="POST" class="d-flex gap-2 flex-wrap align-items-end">
              <div>
                <label class="form-label small text-secondary mb-1">Saldo inicial</label>
                <input type="number" step="0.01" min="0" name="saldo_inicial" class="form-control form-control-sm" value="0">
              </div>
              <div>
                <label class="form-label small text-secondary mb-1">Observação</label>
                <input type="text" name="observacoes" class="form-control form-control-sm" maxlength="180" placeholder="Opcional">
              </div>
              <button type="submit" class="btn btn-sm btn-outline-success">
                <i class="fas fa-unlock me-1"></i>Abrir caixa
              </button>
            </form>
          <% } %>
        </div>
      </div>

      <!-- KPIs -->
      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="card p-4">
            <p class="text-secondary small text-uppercase mb-1">Entradas</p>
            <h3 class="text-success fw-bold mb-0">
              R$ <%= typeof entradas !== 'undefined' ? Number(entradas || 0).toFixed(2) : '0.00' %>
            </h3>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <p class="text-secondary small text-uppercase mb-1">Saídas</p>
            <h3 class="text-danger fw-bold mb-0">
              R$ <%= typeof saidas !== 'undefined' ? Number(saidas || 0).toFixed(2) : '0.00' %>
            </h3>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <p class="text-secondary small text-uppercase mb-1">Saldo Operacional</p>
            <h3 class="text-dourado fw-bold mb-0">
              R$ <%= typeof saldo !== 'undefined' ? Number(saldo || 0).toFixed(2) : '0.00' %>
            </h3>
          </div>
        </div>
      </div>

      <!-- LANÇAMENTO MANUAL -->
      <div class="card p-3 mb-4">
        <h6 class="text-dourado mb-3"><i class="fas fa-pen-to-square me-2"></i>Lançamento manual</h6>
        <form action="/financeiro/movimentacoes" method="POST" class="row g-2 align-items-end">
          <div class="col-md-2">
            <label class="form-label small text-secondary">Tipo</label>
            <select name="tipo" class="form-select form-select-sm" required>
              <option value="ENTRADA">Entrada</option>
              <option value="SAIDA">Saída</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small text-secondary">Origem</label>
            <select name="origem" class="form-select form-select-sm">
              <option value="MANUAL">Manual</option>
              <option value="ATENDIMENTO">Atendimento</option>
              <option value="PRODUTO_BALCAO">Produto balcão</option>
              <option value="RESERVA_VITRINE">Reserva vitrine</option>
              <option value="AJUSTE_CAIXA">Ajuste caixa</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label small text-secondary">Descrição</label>
            <input type="text" name="descricao" class="form-control form-control-sm" maxlength="180" required placeholder="Ex: compra de material">
          </div>
          <div class="col-md-2">
            <label class="form-label small text-secondary">Forma</label>
            <select name="forma_pagamento" class="form-select form-select-sm">
              <option value="Não informado">Não informado</option>
              <option value="Dinheiro">Dinheiro</option>
              <option value="PIX presencial">PIX presencial</option>
              <option value="Débito">Débito</option>
              <option value="Crédito">Crédito</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small text-secondary">Valor</label>
            <input type="number" step="0.01" min="0.01" name="valor" class="form-control form-control-sm" required>
          </div>
          <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-sm btn-outline-warning">Salvar</button>
          </div>
        </form>
      </div>

      <!-- GRÁFICOS -->
      <div class="row g-4 mb-4">
        <div class="col-lg-8">
          <div class="card p-4">
            <h6 class="text-dourado mb-3">Entradas por mês</h6>
            <canvas id="graficoReceita" height="100"></canvas>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card p-4">
            <h6 class="text-dourado mb-3">Formas presenciais</h6>
            <canvas id="graficoPagamento" height="160"></canvas>
          </div>
        </div>
      </div>

      <!-- TABELA DE MOVIMENTAÇÕES -->
      <div class="card p-3 mb-4">
        <h6 class="text-dourado mb-3">Últimas movimentações</h6>
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle">
            <thead>
              <tr>
                <th class="text-secondary small">Data</th>
                <th class="text-secondary small">Tipo</th>
                <th class="text-secondary small">Origem</th>
                <th class="text-secondary small">Descrição</th>
                <th class="text-secondary small">Forma</th>
                <th class="text-secondary small">Status</th>
                <th class="text-secondary small">Valor</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof movimentos !== 'undefined' && movimentos.length) { %>
                <% movimentos.forEach(m => { %>
                  <tr>
                    <td class="text-secondary small"><%= new Date(m.data_movimentacao).toLocaleString('pt-BR') %></td>
                    <td>
                      <span class="badge <%= m.tipo === 'ENTRADA' ? 'bg-success' : 'bg-danger' %>"><%= m.tipo %></span>
                    </td>
                    <td class="text-secondary small"><%= m.origem || 'MANUAL' %></td>
                    <td><%= m.descricao %></td>
                    <td><%= m.forma_pagamento || '—' %></td>
                    <td><span class="badge bg-secondary"><%= m.status_pagamento || 'Pago' %></span></td>
                    <td class="fw-bold <%= m.tipo === 'ENTRADA' ? 'text-success' : 'text-danger' %>">
                      R$ <%= Number(m.valor || 0).toFixed(2) %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="text-center text-secondary py-4">
                    <i class="fas fa-receipt fa-2x mb-2 d-block opacity-25"></i>
                    Nenhuma movimentação financeira registrada ainda.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- HISTÓRICO DE CAIXAS -->
      <div class="card p-3">
        <h6 class="text-dourado mb-3">Últimos caixas</h6>
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle">
            <thead>
              <tr>
                <th class="text-secondary small">Data</th>
                <th class="text-secondary small">Status</th>
                <th class="text-secondary small">Inicial</th>
                <th class="text-secondary small">Entradas</th>
                <th class="text-secondary small">Saídas</th>
                <th class="text-secondary small">Saldo sistema</th>
                <th class="text-secondary small">Saldo final</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof caixasRecentes !== 'undefined' && caixasRecentes.length) { %>
                <% caixasRecentes.forEach(c => { %>
                  <tr>
                    <td class="text-secondary small"><%= c.data_referencia || new Date(c.data_abertura).toLocaleDateString('pt-BR') %></td>
                    <td><span class="badge <%= c.status_caixa === 'Aberto' ? 'bg-success' : 'bg-secondary' %>"><%= c.status_caixa || (c.data_fechamento ? 'Fechado' : 'Aberto') %></span></td>
                    <td>R$ <%= Number(c.saldo_inicial || 0).toFixed(2) %></td>
                    <td class="text-success">R$ <%= Number(c.total_entradas || 0).toFixed(2) %></td>
                    <td class="text-danger">R$ <%= Number(c.total_saidas || 0).toFixed(2) %></td>
                    <td>R$ <%= Number(c.saldo_sistema || 0).toFixed(2) %></td>
                    <td>R$ <%= c.saldo_final !== null && typeof c.saldo_final !== 'undefined' ? Number(c.saldo_final).toFixed(2) : '—' %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="7" class="text-center text-secondary py-4">Nenhum caixa registrado.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/assets/js/admin.js"></script>
  <script>
    const labelsReceita = <%- JSON.stringify(typeof labelsReceita !== 'undefined' ? labelsReceita : []) %>;
    const dadosReceita  = <%- JSON.stringify(typeof dadosReceita  !== 'undefined' ? dadosReceita  : []) %>;
    const labelsPagto   = <%- JSON.stringify(typeof labelsPagto   !== 'undefined' ? labelsPagto   : []) %>;
    const dadosPagto    = <%- JSON.stringify(typeof dadosPagto    !== 'undefined' ? dadosPagto    : []) %>;

    StudioCharts.linha('graficoReceita', labelsReceita.length ? labelsReceita : ['Sem dados'], [{
      label: 'Entradas (R$)',
      data: dadosReceita.length ? dadosReceita : [0],
      borderColor: '#ffc400',
      backgroundColor: 'rgba(255,196,0,0.08)',
      fill: true,
      tension: 0.4,
    }]);

    StudioCharts.rosca('graficoPagamento', labelsPagto.length ? labelsPagto : ['Sem dados'], dadosPagto.length ? dadosPagto : [0],
      ['#ffc400','#4ade80','#60a5fa','#f87171']
    );
  </script>

</body>
</html>
