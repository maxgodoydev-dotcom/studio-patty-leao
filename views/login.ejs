<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('partials/head', { titulo: 'Login' }) %>
</head>

<body data-bs-theme="dark">

  <%- include('partials/navbar', { paginaAtiva: 'login' }) %>

  <main class="d-flex justify-content-center align-items-center py-5 mt-4 min-vh-75">

    <div class="formulario">

      <div class="text-center mb-4">
        <h1 class="titulo-form">Entrar</h1>
        <p class="text-secondary small">Acesse sua conta no Studio Patty Leão</p>
      </div>

      <% if (typeof erro !== 'undefined' && erro) { %>
        <div class="alert alert-danger border-0 rounded-0 small mb-3">
          <i class="fas fa-exclamation-triangle me-2"></i><%= erro %>
        </div>
      <% } %>

      <form action="/auth/login" method="POST">

        <div class="mb-3">
          <label for="email" class="form-label small text-secondary">E-mail</label>
          <div class="input-group">
            <span class="input-group-text bg-transparent border-0">
              <i class="fas fa-envelope text-secondary"></i>
            </span>
            <input type="email" class="form-control confirmar" id="email" name="email"
              placeholder="seuemail@exemplo.com" required autocomplete="email">
          </div>
        </div>

        <div class="mb-4">
          <label for="senha" class="form-label small text-secondary">Senha</label>
          <div class="input-group">
            <span class="input-group-text bg-transparent border-0">
              <i class="fas fa-lock text-secondary"></i>
            </span>
            <input type="password" class="form-control confirmar" id="senha" name="senha"
              placeholder="••••••••" required autocomplete="current-password">
          </div>
        </div>

        <button type="submit" class="btn-dourado w-100 mb-3">
          <i class="fas fa-sign-in-alt me-2"></i>ENTRAR
        </button>

      </form>

      <p class="text-center small text-secondary mt-3">
        Não tem conta?
        <a href="/cadastro" class="text-dourado fw-bold">Cadastre-se</a>
      </p>

    </div>

  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/assets/js/navbar.js"></script>

</body>
</html>
