<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('partials/head', { titulo: 'Cadastro' }) %>
</head>

<body data-bs-theme="dark">

  <%- include('partials/navbar', { paginaAtiva: 'cadastro' }) %>

  <main class="d-flex justify-content-center align-items-center py-5 mt-4">

    <div class="formulario">

      <div class="text-center mb-4">
        <h1 class="titulo-form">Criar Conta</h1>
        <p class="text-secondary small">Preencha os dados para se cadastrar</p>
      </div>

      <% if (typeof erro !== 'undefined' && erro) { %>
        <div class="alert alert-danger border-0 rounded-0 small mb-3">
          <i class="fas fa-exclamation-triangle me-2"></i><%= erro %>
        </div>
      <% } %>

      <form action="/auth/register" method="POST">

        <div class="mb-3">
          <label for="nome" class="form-label small text-secondary">Nome completo</label>
          <input type="text" class="form-control confirmar" id="nome" name="nome"
            placeholder="Seu nome" required>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label small text-secondary">E-mail</label>
          <input type="email" class="form-control confirmar" id="email" name="email"
            placeholder="seuemail@exemplo.com" required autocomplete="email">
        </div>

        <div class="mb-3">
          <label for="telefone" class="form-label small text-secondary">Telefone</label>
          <input type="tel" class="form-control confirmar" id="telefone" name="telefone"
            placeholder="(11) 99999-9999">
        </div>

        <div class="mb-3">
          <label for="cpf" class="form-label small text-secondary">CPF <span class="text-secondary">(opcional)</span></label>
          <input type="text" class="form-control confirmar" id="cpf" name="cpf"
            placeholder="Somente números, se desejar informar" maxlength="11" pattern="\d{11}">
          <small class="text-secondary">O CPF não é obrigatório para agendar serviços.</small>
        </div>

        <div class="mb-3">
          <label for="senha" class="form-label small text-secondary">Senha</label>
          <input type="password" class="form-control confirmar" id="senha" name="senha"
            placeholder="Mínimo 6 caracteres" required minlength="6" autocomplete="new-password">
        </div>

        <div class="mb-4">
          <label for="confirmarSenha" class="form-label small text-secondary">Confirmar senha</label>
          <input type="password" class="form-control confirmar" id="confirmarSenha" name="confirmarSenha"
            placeholder="Repita a senha" required minlength="6">
        </div>

        <!-- ALERGIA -->
        <div class="caixa-alergia p-3 mb-4 rounded">
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="flgAlergico" name="flgAlergico"
              onchange="toggleAlergia(this)">
            <label class="form-check-label text-secondary small" for="flgAlergico">
              Possuo alergia a algum produto
            </label>
          </div>
          <div id="campoAlergia" style="display:none;">
            <textarea class="form-control mt-2" name="detalhesAlergia" rows="2"
              placeholder="Descreva sua alergia..."></textarea>
          </div>
        </div>

        <button type="submit" class="btn-dourado w-100 mb-3">
          <i class="fas fa-user-plus me-2"></i>CRIAR CONTA
        </button>

      </form>

      <p class="text-center small text-secondary mt-3">
        Já tem conta?
        <a href="/login" class="text-dourado fw-bold">Fazer login</a>
      </p>

    </div>

  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/assets/js/navbar.js"></script>
  <script>
    function toggleAlergia(checkbox) {
      document.getElementById('campoAlergia').style.display = checkbox.checked ? 'block' : 'none';
    }
  </script>

</body>
</html>
